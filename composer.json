{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "bladeuix/daisyui",
    "description": "A Laravel blade component library based on daisyUI.",
    "keywords": [
        "laravel",
        "daisyui",
        "blade"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2 | ^8.3 | ^8.4 | ^8.5",
        "illuminate/support": "^12.0 | ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.0 | ^11.0",
        "pestphp/pest": "^3.0 | ^4.0"
    },
    "autoload": {
        "psr-4": {
            "BladeUix\\DaisyUi\\": "src/",
            "BladeUix\\DaisyUi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "format": "./vendor/bin/pint --parallel",
        "test": "./vendor/bin/pest --parallel"
    },
    "extra": {
        "laravel": {
            "providers": [
                "BladeUix\\DaisyUi\\Providers\\DaisyUiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "archive": {
        "exclude": [
            "/.github",
            "/.gitignore"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
