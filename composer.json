{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "bladeuix/daisyui",
    "description": "LadaisyUI Blade Components for BladeUix",
    "keywords": [
        "laravel",
        "daisyui",
        "blade"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2 | ^8.3 | ^8.4 | ^8.5",
        "illuminate/support": "^10.0 | ^11.0 | ^12.0 | ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "BladeUix\\DaisyUi\\": "src/"
        }
    },
    "scripts": {
        "format": "./vendor/bin/pint --parallel"
    },
    "extra": {
        "laravel": {
            "providers": [
                "BladeUix\\DaisyUi\\Providers\\DaisyUiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
