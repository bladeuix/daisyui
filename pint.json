{
    "preset": "psr12",
    "rules": {
        "declare_strict_types": true,
        "ordered_traits": true,
        "binary_operator_spaces": {
            "operators": {
                "=>": "align_single_space_minimal"
            }
        },
        "array_syntax": {
            "syntax": "short"
        },
        "ordered_imports": {
            "sort_algorithm": "length"
        }
    }
}
